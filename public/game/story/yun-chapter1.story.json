{
  "version": 1,
  "id": "yun-chapter1",
  "title": "折光三则：第一则 画页之城",
  "startNode": "T1_01",
  "variables": {
    "trust": 0,
    "science": 0,
    "risk": 0,
    "heat": 0,
    "politics": 0,
    "worlds": 0,
    "clue_flatten": 0,
